# 3x-ui panel credentials
XUI_USERNAME=admin
XUI_PASSWORD=change_me_strong_password

# URL to reach 3x-ui from inside Docker network (do not change)
XUI_URL=http://3xui:2053

# Your server IP or domain — used in all VLESS subscription links
# When this changes, restart the subscription container and all clients update automatically
SERVER_DOMAIN=YOUR_SERVER_IP_OR_DOMAIN

# Secret token protecting the admin API (generate with: openssl rand -hex 32)
ADMIN_TOKEN=REPLACE_WITH_RANDOM_SECRET

# ID of the VLESS Reality inbound in 3x-ui (usually 1 after first setup)
INBOUND_ID=1
